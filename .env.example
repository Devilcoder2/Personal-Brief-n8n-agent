# Database Configuration (PostgreSQL + pgvector)
DB_USER=postgres
DB_PASSWORD=postgres_local_password_secure
DB_HOST=db
DB_PORT=5432
DB_HOST_PORT=5436
DB_NAME=briefing_db

# Ollama LLM Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=qwen2.5:7b-instruct

# SMTP Mail Server Configuration (For n8n Email Node and error alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_SENDER=briefing-bot@example.com
SMTP_RECEIVER=your_email@gmail.com

# n8n Service Configuration
N8N_PORT=5678
N8N_ENCRYPTION_KEY=generate_a_random_string_here_32_chars

# FastAPI Helper API Configuration
API_PORT=8000
API_HOST=0.0.0.0
